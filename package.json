{
  "name": "rs4it-mcp-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev:backend:http": "npm --prefix apps/backend run dev:server",
    "build:backend": "npm --prefix apps/backend run build",
    "start:backend": "npm --prefix apps/backend run start",
    "start:backend:http": "npm --prefix apps/backend run start:server",

    "dev:admin": "npm --prefix apps/admin run dev",
    "build:admin": "npm --prefix apps/admin run build",
    "start:admin": "npm --prefix apps/admin run start",

    "prisma:generate": "npm --prefix apps/backend run prisma:generate",
    "prisma:migrate": "npm --prefix apps/backend run prisma:migrate",
    "prisma:studio": "npm --prefix apps/backend run prisma:studio"
  }
}

