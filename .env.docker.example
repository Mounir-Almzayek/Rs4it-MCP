# -----------------------------------------------------------------------------
# Docker Compose — copy to .env and adjust
# -----------------------------------------------------------------------------
# Required for Admin Panel auth (min 16 chars). Generate: openssl rand -base64 24
SESSION_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# Production (Hub behind HTTPS / reverse proxy)
# -----------------------------------------------------------------------------
# When Cursor connects to https://your-domain.com/mcp, the Host header is your domain.
# The Hub must allow that host or you get "Invalid Host". Set it here (no spaces).
# Example:
# MCP_ALLOWED_HOSTS=rs4it-mcp.ai.system2030.com
# HUB_BASE_URL=https://rs4it-mcp.ai.system2030.com
#
# MCP_ALLOWED_HOSTS=your-mcp-domain.com
# HUB_BASE_URL=https://your-mcp-domain.com

# -----------------------------------------------------------------------------
# Optional overrides
# -----------------------------------------------------------------------------
# Hub
# HUB_PORT=3000
# HUB_BASE_URL=http://localhost:3000
# MCP_WORKSPACE_ROOT=/workspace

# Admin
# ADMIN_PORT=3001

# Host path for workspace (file tools). Use . for ./workspace, or /path/to/real/workspace
# WORKSPACE_PATH=./workspace
